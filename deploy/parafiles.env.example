# Native server environment file for systemd.
# Copy to /srv/parafiles/.env and replace every placeholder.

DJANGO_SECRET_KEY=replace-with-long-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=parafiles.net
DJANGO_CSRF_TRUSTED_ORIGINS=https://parafiles.net
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_USE_X_FORWARDED_HOST=false
DJANGO_TIME_ZONE=UTC

DEFAULT_FROM_EMAIL=noreply@parafiles.net
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
PARAFILES_EMAIL_VERIFICATION_TIMEOUT=259200

# URL-encode the database password if it contains special URL characters.
DATABASE_URL=postgres://parafiles:replace-with-url-encoded-password@127.0.0.1:5432/parafiles
REDIS_URL=redis://127.0.0.1:6379/0

PARAFILES_SITE_NAME=Parafiles
PARAFILES_STORAGE_ROOT=/srv/data/allfiles/parafiles/private_uploads
PARAFILES_UPLOAD_SESSION_ROOT=/srv/data/allfiles/parafiles/upload_sessions
PARAFILES_UPLOAD_STAGING_RETENTION_SECONDS=604800
PARAFILES_INTERNAL_DOWNLOAD_PREFIX=/protected-files/
PARAFILES_SERVE_PRIVATE_DOWNLOADS=false
PARAFILES_SCAN_SYNC=false
PARAFILES_ALLOW_SCAN_BYPASS=false
PARAFILES_CLAMAV_COMMAND=clamscan
PARAFILES_SIGNATURE_PRIVATE_KEY=replace-with-base64-32-byte-ed25519-private-key
PARAFILES_SIGNATURE_PUBLIC_KEY=replace-with-derived-base64-32-byte-ed25519-public-key
PARAFILES_ADMIN_2FA_REQUIRED=true
OTP_TOTP_ISSUER=Parafiles

PARAFILES_DEFAULT_QUOTA_BYTES=10737418240
PARAFILES_DEFAULT_MAX_FILE_SIZE_BYTES=1073741824
PARAFILES_DEFAULT_MAX_FILE_COUNT=10000
PARAFILES_DEFAULT_MAX_FOLDER_DEPTH=20
PARAFILES_DOWNLOAD_TOKEN_TTL_SECONDS=90
PARAFILES_CONCURRENT_DOWNLOADS_PER_IP=4
PARAFILES_DAILY_IP_BANDWIDTH_BYTES=5368709120
PARAFILES_REPORTS_PER_IP_PER_HOUR=5
PARAFILES_DOWNLOADS_PER_IP_PER_MINUTE=30
PARAFILES_PUBLIC_PAGE_VIEWS_PER_IP_PER_MINUTE=120
PARAFILES_SLOWDOWN_BYTES_PER_SECOND=131072

VIRUSTOTAL_API_KEY=
VIRUSTOTAL_SUBMIT_FILES=false
